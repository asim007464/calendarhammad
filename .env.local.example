# Supabase — create project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=https://www.qsodates.com

# Gmail SMTP — auth emails (verification, password reset)
SMTP_EMAIL=your@gmail.com
SMTP_APP_PASSWORD=your-gmail-app-password

# Admin notification inbox (optional)
NOTIFY_EMAIL=your-notify@gmail.com

# Super-admin emails (comma-separated or single ADMIN_EMAIL)
ADMIN_EMAIL=your-admin@gmail.com

# Social auto-post (optional — configure per platform)
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# External feeds (optional)
EHAMHUB_API_KEY=
CQHAMS_API_KEY=
